# ───────────────────────────────────────────────────────────────
# ThuleMail — пример переменных окружения. Скопируйте в .env и заполните.
# ───────────────────────────────────────────────────────────────

# Окружение: "dev" допускает небезопасные дефолты, "prod" — НЕТ
# (старт упадёт, если секреты дефолтные/пустые или COOKIE_SECURE=false).
ENVIRONMENT=prod

# Секрет для подписи JWT-сессии приложения (длинная случайная строка, >=16 симв.).
# Сгенерировать:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Ключ Fernet для шифрования учёток почтовых ящиков на диске. В prod ОБЯЗАТЕЛЕН.
# Сгенерировать:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-valid-fernet-key

# Учётка единственного пользователя приложения (self-hosted). Смените пароль!
APP_USER=admin
APP_PASSWORD=change-me

# Cookie сессии только по HTTPS. За TLS-прокси в prod — true.
COOKIE_SECURE=true

# Порт, на котором приложение (UI + API) доступно снаружи (docker-compose).
APP_PORT=8000

# CORS нужен ТОЛЬКО для отдельного dev-фронта (vite dev на :3000).
# В проде фронт раздаётся бэком с того же origin — можно оставить пустым.
ALLOWED_ORIGINS=

# Путь к файлу SQLite-кэша (внутри контейнера/процесса).
DATABASE_PATH=./data/thulemail.db

# Каталог собранного фронта. В Docker задаётся образом (/app/frontend_dist).
# Локально пусто = автоопределение ../frontend/dist.
STATIC_DIR=

# Параметры пула IMAP-соединений.
IMAP_POOL_SIZE=3

# Интервал фоновой синхронизации по умолчанию (секунды).
SYNC_INTERVAL_SECONDS=60
